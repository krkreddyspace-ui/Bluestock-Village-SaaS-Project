generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id    Int     @id @default(autoincrement())
  code  String  @unique
  name  String
  states State[]
}

model State {
  id        Int       @id @default(autoincrement())
  code      String    @unique
  name      String
  countryId Int
  country   Country   @relation(fields: [countryId], references: [id])
  districts District[]
  userAccess UserStateAccess[]
}

model District {
  id           Int           @id @default(autoincrement())
  code         String        @unique
  name         String
  stateId      Int
  state        State         @relation(fields: [stateId], references: [id])
  subDistricts SubDistrict[]
}

model SubDistrict {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  name       String
  districtId Int
  district   District  @relation(fields: [districtId], references: [id])
  villages   Village[]
}

model Village {
  id            Int         @id @default(autoincrement())
  code          String      @unique
  name          String
  subDistrictId Int
  subDistrict   SubDistrict @relation(fields: [subDistrictId], references: [id])
  
  @@index([name])
}

model User {
  id            Int               @id @default(autoincrement())
  email         String            @unique
  businessName  String
  passwordHash  String
  planType      PlanType          @default(FREE)
  status        UserStatus        @default(PENDING_APPROVAL)
  role          Role              @default(CLIENT)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  apiKeys       ApiKey[]
  stateAccess   UserStateAccess[]
}

enum Role {
  ADMIN
  CLIENT
}

model ApiKey {
  id         Int      @id @default(autoincrement())
  name       String
  key        String   @unique
  secretHash String
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  lastUsed   DateTime?
  logs       ApiLog[]
}

model UserStateAccess {
  id      Int   @id @default(autoincrement())
  userId  Int
  stateId Int
  user    User  @relation(fields: [userId], references: [id])
  state   State @relation(fields: [stateId], references: [id])

  @@unique([userId, stateId])
}

model ApiLog {
  id           Int      @id @default(autoincrement())
  apiKeyId     Int?
  apiKey       ApiKey?  @relation(fields: [apiKeyId], references: [id])
  endpoint     String
  method       String
  status       Int
  responseTime Int
  ipAddress    String?
  createdAt    DateTime @default(now())
}

enum PlanType {
  FREE
  PREMIUM
  PRO
  UNLIMITED
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
}
